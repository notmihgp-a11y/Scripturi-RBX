-- SECTION: COMBAT & HITBOX
main:section("combat")

main:toggle("Auto Skill & Big Hitbox", false, function(state)
    _G.AutoSkill = state
    
    task.spawn(function()
        while _G.AutoSkill do
            pcall(function()
                local char = game:GetService("Players").LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                
                if hrp and hrp:FindFirstChild("Skill1Box") then
                    -- Mărește Hitbox-ul (Skill1Box)
                    hrp.Skill1Box.Size = Vector3.new(2000, 2000, 2000)
                    hrp.Skill1Box.CanCollide = false
                    hrp.Skill1Box.Massless = true
                    
                    -- Trimite atacul către server
                    local Event = game:GetService("ReplicatedStorage").BerserkerRemotes.BerSkill1_1
                    Event:FireServer(
                        7000010,
                        hrp:FindFirstChild("Cut"),
                        hrp:FindFirstChild("sword slash"),
                        hrp:FindFirstChild("Weapon Hit Blade Flesh"),
                        hrp.Skill1Box,
                        char:FindFirstChild("CauseBleed"),
                        char:FindFirstChild("CauseBurn"),
                        1000030,
                        200000,
                        char:FindFirstChild("DamageBuff"),
                        char:FindFirstChild("BloodBath"),
                        char:FindFirstChild("Retaliation"),
                        1000,
                        1000
                    )
                end
            end)
            task.wait(0.1) -- Trmite atacul rapid (la fiecare 0.1 secunde)
        end
        
        -- Când oprești butonul (Off), resetează hitboxul la mărimea normală
        if not _G.AutoSkill then
            pcall(function()
                local box = game:GetService("Players").LocalPlayer.Character.HumanoidRootPart.Skill1Box
                box.Size = Vector3.new(2, 2, 2) -- Mărime default aproximativă
            end)
        end
    end)
end, "auto_skill")

