-- Toggle Auto Add
main:toggle("Auto Add", false, function(state)
    _G.AddLoop = state
    if state then
        w:notify("Auto Add", "Pornit pe " .. _G.SelectedBase, 2)
        task.spawn(function()
            while _G.AddLoop do
                local Backpack = game.Players.LocalPlayer:FindFirstChild("Backpack")
                if Backpack then
                    for _, item in ipairs(Backpack:GetChildren()) do
                        if string.find(item.Name, "Fuel") then
                            local EquipEvent = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.InventoryService.RF.Equip
                            local Result1 = EquipEvent:InvokeServer(item)
                            local ExpectedResult1 = table.unpack({})
                            
                            task.wait(0.1)
                            
                            local AddEvent = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.BoatService.RF.AddFuel
                            if workspace.Bases:FindFirstChild(_G.SelectedBase) then
                                local Result2 = AddEvent:InvokeServer(workspace.Bases[_G.SelectedBase].SailPad.ClickProxy)
                                local ExpectedResult2 = table.unpack({})
                            end
                            
                            task.wait(0.2)
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    else
        w:notify("Auto Add", "Oprit", 2)
    end
end, "add_toggle")

