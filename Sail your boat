-- Toggle Fuel
main:toggle("Auto Fuel", false, function(state)
    _G.FuelLoop = state
    if state then
        w:notify("Fuel", "Auto-tick pornit pe " .. _G.SelectedBase, 2)
        task.spawn(function()
            while _G.FuelLoop do
                local Event = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.FuelService.RF.ManualTick
                if workspace.Bases:FindFirstChild(_G.SelectedBase) then
                    Event:InvokeServer(workspace.Bases[_G.SelectedBase].FuelPlaces.FuelPlace1)
                end
                task.wait(0.01) 
            end
        end)
    else
        w:notify("Fuel", "Auto-tick oprit", 2)
    end
end, "fuel_toggle")

